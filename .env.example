# formula-service environment configuration
#
# Copy this file to `.env` and adjust the values for your environment.
# `.env` is in .gitignore so your local secrets stay out of version
# control. The defaults below match what the backend uses when an
# environment variable is unset.
#
# All variables are documented in `backend/internal/config/config.go`
# (function `Load`). Required for production: AUTH_JWT_SECRET.

# ─────────────────────────────────────────────────────────────────
# HTTP server
# ─────────────────────────────────────────────────────────────────

# Port the backend listens on. Must be 1..65535.
SERVER_PORT=8080

# Comma-separated list of CORS allow-origin entries. Default lets the
# Vite dev server on localhost:5173 talk to the backend.
SERVER_CORS_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# Database — pick exactly one driver and the matching DSN
# ─────────────────────────────────────────────────────────────────

# Supported drivers: sqlite | postgres | mysql
DB_DRIVER=sqlite

# DSN for the chosen driver. Examples below — uncomment the one
# matching DB_DRIVER above.

# SQLite (default)
DB_DSN=file:formula.db?_journal=WAL&_foreign_keys=on

# PostgreSQL
# DB_DRIVER=postgres
# DB_DSN=postgres://formula:formula_dev@localhost:5432/formula_service?sslmode=disable

# MySQL
# DB_DRIVER=mysql
# DB_DSN=formula:formula_dev@tcp(localhost:3306)/formula_service?parseTime=true&charset=utf8mb4&loc=UTC

# ─────────────────────────────────────────────────────────────────
# docker-compose profile selection
# ─────────────────────────────────────────────────────────────────
#
# COMPOSE_PROFILES picks which services in docker-compose.yml are
# started. Three profiles are defined:
#   sqlite   — default; runs the backend with the embedded SQLite file
#   postgres — runs a PostgreSQL container plus the backend wired to it
#   mysql    — runs a MySQL container plus the backend wired to it
#
# Override on the command line if you don't want to set this in .env:
#   docker compose --profile postgres up
COMPOSE_PROFILES=sqlite

# ─────────────────────────────────────────────────────────────────
# Calculation engine
# ─────────────────────────────────────────────────────────────────

# Worker pool size for parallel DAG execution. 0 = use runtime.NumCPU().
ENGINE_MAX_WORKERS=0

# Decimal precision used for intermediate calculations (digits after the
# decimal point). Higher = more accurate, slightly slower.
ENGINE_INTERMEDIATE_PRECISION=28

# Decimal precision for final output values returned by the API.
ENGINE_OUTPUT_PRECISION=18

# Minimum number of nodes in a DAG level before parallel execution kicks
# in. Below this threshold the level runs sequentially to avoid the
# goroutine overhead on tiny graphs.
ENGINE_PARALLEL_THRESHOLD=8

# Result cache capacity (number of cached formula calculation results).
ENGINE_CACHE_SIZE=1000

# Global cap on concurrent /calculate calls. Excess requests get HTTP 503
# and a Retry-After header. Set to 0 for unlimited (not recommended in
# production). The batch-test endpoint uses floor(value/5) workers per
# request, so this also bounds the batch parallelism.
ENGINE_MAX_CONCURRENT_CALCS=100

# ─────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────

# JWT signing secret. REQUIRED in production — leaving this empty in a
# real deployment will let anyone forge admin tokens. The example value
# below is fine for local development only.
AUTH_JWT_SECRET=change-me-in-production

# How long an issued JWT stays valid. Accepts Go duration syntax
# (e.g. "24h", "30m", "168h").
AUTH_TOKEN_EXPIRY=24h

# ─────────────────────────────────────────────────────────────────
# Database container credentials (only used when COMPOSE_PROFILES
# includes postgres or mysql — these populate the postgres/mysql
# service blocks in docker-compose.yml so the matching DB_DSN above
# can connect)
# ─────────────────────────────────────────────────────────────────

POSTGRES_DB=formula_service
POSTGRES_USER=formula
POSTGRES_PASSWORD=formula_dev

MYSQL_DATABASE=formula_service
MYSQL_USER=formula
MYSQL_PASSWORD=formula_dev
MYSQL_ROOT_PASSWORD=formula_root_dev
